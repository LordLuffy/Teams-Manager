{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Teams Manager",
  "version": "1.2.0",
  "identifier": "com.teams-manager.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Teams Manager",
        "width": 1300,
        "height": 820,
        "maximized": true,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxRDU4QTdFNjk2OUU3RjIKUldUeTUybHBmb3JWUWFnUnlZQ3B0dlNIKzNTejlZTTNka1hZc0F0UEk4OGkvaFp6RFh6ZFF6YzkK",
      "endpoints": [
        "https://github.com/Xenovyrion/Teams-Manager/releases/latest/download/latest.json"
      ]
    }
  }
}
